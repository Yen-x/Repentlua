local KeyDownConnection, KeyUpConnection
 
local function SetupKeybindHandling()
    if KeyDownConnection then KeyDownConnection:Disconnect() end
    if KeyUpConnection then KeyUpConnection:Disconnect() end
 
    KeyDownConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
 
        -- Handle MouseButton1 for Silent Aim
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if SilentAimEnabled then
                SilentAim()
            end
            return
        end
 
        local keyCode
        local success = pcall(function()
            keyCode = Enum.KeyCode[AimlockKey]
        end)
 
        if success and input.KeyCode == keyCode then
            IsKeyDown = true
        end
    end)
 
    KeyUpConnection = UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if gameProcessed then return end
 
        local keyCode
        local success = pcall(function()
            keyCode = Enum.KeyCode[AimlockKey]
        end)
 
        if success and input.KeyCode == keyCode then
            IsKeyDown = false
        end
    end)
end
 
