-- Backtrack Visuals Functions
local function UpdateBacktrackVisuals()
    if not BacktrackEnabled then return end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            -- R6 uses Torso instead of HumanoidRootPart
            local torso = player.Character:FindFirstChild("Torso")
            local humanoid = player.Character:FindFirstChild("Humanoid")

            if torso and humanoid and humanoid.Health > 0 then
                -- Initialize history for this player if not exists
                if not BacktrackHistory[player] then
                    BacktrackHistory[player] = {
                        Positions = {},
                        Dots = {},
                        LastUpdate = 0
                    }
                end

                local data = BacktrackHistory[player]
                local currentTime = tick()

                -- Update position history every 0.05 seconds
                if currentTime - data.LastUpdate >= 0.05 then
                    data.LastUpdate = currentTime

                    -- Add new position
                    table.insert(data.Positions, 1, torso.Position)

                    -- Remove old positions
                    if #data.Positions > BacktrackMaxHistory then
                        table.remove(data.Positions)
                    end

                    -- Create/update dots
                    for i, pos in ipairs(data.Positions) do
                        if not data.Dots[i] then
                            local dot = Instance.new("Part")
                            dot.Name = "BacktrackDot"
                            dot.Shape = Enum.PartType.Ball
                            dot.Size = Vector3.new(0.3, 0.3, 0.3)
                            dot.Anchored = true
                            dot.CanCollide = false
                            dot.Material = Enum.Material.Neon
                            dot.Color = BacktrackDotColor
                            dot.Transparency = 0.3 + (i / BacktrackMaxHistory) * 0.5
                            dot.Parent = Workspace
                            data.Dots[i] = dot
                        end

                        -- Update dot position
                        data.Dots[i].CFrame = CFrame.new(pos)
                        -- Fade older dots
                        data.Dots[i].Transparency = 0.3 + (i / BacktrackMaxHistory) * 0.5
                    end

                    -- Remove excess dots
                    for i = #data.Positions + 1, #data.Dots do
                        if data.Dots[i] then
                            data.Dots[i]:Destroy()
                            data.Dots[i] = nil
                        end
                    end
                end
            else
                -- Clear visuals if player is dead or no character
                if BacktrackHistory[player] then
                    if BacktrackHistory[player].Dots then
                        for _, dot in pairs(BacktrackHistory[player].Dots) do
                            if dot then
                                dot:Destroy()
                            end
                        end
                    end
                    BacktrackHistory[player] = nil
                end
            end
        end
    end
end

-- Velocity Visualizer Functions
local function UpdateVelocityVisualizer()
    if not VelocityVisualizerEnabled or not LocalPlayer.Character then return end

    -- R6 uses Torso instead of HumanoidRootPart
    local torso = LocalPlayer.Character:FindFirstChild("Torso")
    if not torso then return end

    local velocity = torso.Velocity
    local horizontalVelocity = Vector3.new(velocity.X, 0, velocity.Z)

    if not VelocityLine then
        VelocityLine = Drawing.new("Line")
        VelocityLine.Thickness = 2
        VelocityLine.Color = Color3.fromRGB(0, 255, 255) -- Cyan
    end

    local startPos = torso.Position
    local endPos = startPos + horizontalVelocity * 0.1

    local startScreen, startVisible = Camera:WorldToViewportPoint(startPos)
    local endScreen, endVisible = Camera:WorldToViewportPoint(endPos)

    if startVisible and endVisible then
        VelocityLine.From = Vector2.new(startScreen.X, startScreen.Y)
        VelocityLine.To = Vector2.new(endScreen.X, endScreen.Y)
        VelocityLine.Visible = true
    else
        VelocityLine.Visible = false
    end
end


 

 
 
-- Bullet Tracer from Gun Muzzle - Detects actual gun firing
local LastTracerTime = 0
local TracerCooldown = 1.2 -- Minimum time between tracers (prevents spam)
 
local function MonitorGunFiring()
    -- Monitor M1 clicks and check if sniper is equipped
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if not BulletTracerEnabled then return end
 
        -- Cooldown check
        local currentTime = tick()
        if currentTime - LastTracerTime < TracerCooldown then
            return
        end
        LastTracerTime = currentTime
 
        local character = LocalPlayer.Character
        if not character then return end
 
        -- Check if any tool is currently equipped
        local tool = character:FindFirstChildOfClass("Tool")
        if not tool then return end
 
        local muzzle = tool:FindFirstChild("Muz") or tool:FindFirstChild("Muzzle")
        if not muzzle then return end
 
FireBulletTracerFromMuzzle(muzzle)
    end)
end
 
MonitorGunFiring()
 
-- Anti Aimbot Logic - Manipulates character orientation to mess with aimbot
local RapidYawTime = 0
local LastJitterUpdate = 0
local CurrentJitterYaw = 0
RunService.RenderStepped:Connect(function(deltaTime)
    if AntiAimbotEnabled and LocalPlayer.Character then
        local torso = LocalPlayer.Character:FindFirstChild("Torso")
        if torso then
            local pitch = math.rad(AntiAimbotPitch)
            local yaw = math.rad(AntiAimbotYaw)
 
            -- Rapid yaw oscillation
            if AntiAimbotRapidYaw then
                RapidYawTime = RapidYawTime + deltaTime * AntiAimbotRapidYawSpeed
                yaw = math.rad(180 * math.sin(RapidYawTime))
            end
 
            -- Add jitter if enabled (with speed control)
            if AntiAimbotYawJitter then
                local currentTime = tick()
                local jitterInterval = 1 / AntiAimbotJitterSpeed
                if currentTime - LastJitterUpdate >= jitterInterval then
                    CurrentJitterYaw = math.rad(math.random(-30, 30))
                    LastJitterUpdate = currentTime
                end
                yaw = yaw + CurrentJitterYaw
            end
 
            -- Apply rotation to torso (visual only, doesn't affect camera)
            local currentCFrame = torso.CFrame
            local newRotation = CFrame.Angles(pitch, yaw, 0)
            torso.CFrame = CFrame.new(currentCFrame.Position) * newRotation
        end
    end
end)
 
