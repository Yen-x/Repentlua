-- R6 Character Support for Sense
Sense.getCharacter = function(player)
    return player.Character
end
 
Sense.isFriendly = function(player)
    if player.Team and LocalPlayer.Team then
        return player.Team == LocalPlayer.Team
    end
    return false
end
 
Sense.getWeapon = function(player)
    local character = Sense.getCharacter(player)
    if character then
        for _, child in pairs(character:GetChildren()) do
            if child:IsA("Tool") then
                return child.Name
            end
        end
    end
    return "None"
end
 
--Chams
local ChamsEnabled = false
local ChamsColor = Color3.fromRGB(0, 255, 0)
local ChamsEnemyColor = Color3.fromRGB(255, 0, 0)
local ChamsWallColor = Color3.fromRGB(255, 255, 255) -- White for behind walls
local ChamInstances = {}
local WallChams = false

-- Chams Functions
local function ClearChams(player)
    if ChamInstances[player] then
        local chamData = ChamInstances[player]
        if chamData.Highlight then
            chamData.Highlight:Destroy()
        end
        if chamData.Light then
            chamData.Light:Destroy()
        end
        ChamInstances[player] = nil
    end
end

local function ApplyChams(player)
    if not player or not player.Character then return end
    if ChamInstances[player] then return end -- Already has chams

    local character = player.Character
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ChamHighlight"
    highlight.Adornee = character
    highlight.FillColor = ChamsEnemyColor
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0

    -- Wall check toggle
    if WallChams then
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    else
        highlight.DepthMode = Enum.HighlightDepthMode.Occluded
    end
    highlight.Parent = character

    -- Subtle glow effect
    local torso = character:FindFirstChild("Torso")
    local light = nil
    if torso then
        light = Instance.new("PointLight")
        light.Color = ChamsEnemyColor
        light.Brightness = 0.5
        light.Range = 5
        light.Parent = torso
    end

    ChamInstances[player] = {
        Highlight = highlight,
        Light = light
    }
end

local function UpdateAllChams()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                -- Clear existing and reapply
                ClearChams(player)
                if ChamsEnabled then
                    ApplyChams(player)
                end
            else
                ClearChams(player)
            end
        end
    end
end

-- Monitor players for chams
local function SetupChamsMonitoring()
    -- Apply chams to existing players
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if player.Character then
                local humanoid = player.Character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 and ChamsEnabled then
                    ApplyChams(player)
                end

                -- Monitor death
                humanoid.Died:Connect(function()
                    ClearChams(player)
                end)
            end

            -- Monitor respawn
            player.CharacterAdded:Connect(function(character)
                -- Clear old chams first
                ClearChams(player)

                local humanoid = character:WaitForChild("Humanoid")

                -- Wait for character to fully load
                task.wait(0.2)

                -- Apply chams if enabled and player is alive
                if ChamsEnabled and humanoid.Health > 0 then
                    ApplyChams(player)
                end

                -- Monitor death for this character
                humanoid.Died:Connect(function()
                    ClearChams(player)
                end)
            end)
        end
    end

    -- Monitor new players joining
    Players.PlayerAdded:Connect(function(player)
        if player == LocalPlayer then return end

        player.CharacterAdded:Connect(function(character)
            ClearChams(player)

            local humanoid = character:WaitForChild("Humanoid")
            task.wait(0.5)

            if ChamsEnabled and humanoid.Health > 0 then
                ApplyChams(player)
            end

            humanoid.Died:Connect(function()
                ClearChams(player)
            end)
        end)

        -- Check if player already has a character
        if player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 and ChamsEnabled then
                ApplyChams(player)
            end
        end
    end)

    -- Clean up when players leave
    Players.PlayerRemoving:Connect(function(player)
        ClearChams(player)
    end)
end

