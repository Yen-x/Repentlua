-- Reapply 3rd person settings after death
local function SetupDeathMonitoring()
    -- Monitor character changes (respawns) - More robust monitoring
    LocalPlayer.CharacterAdded:Connect(function(character)
        spawn(function()
            -- Wait for character to fully load
            local humanoid = character:WaitForChild("Humanoid")
 
            -- Reapply 3rd person settings after respawn
            wait(0.5) -- Small delay for respawn
            ApplyThirdPersonSettings()
            UpdateBodyTransparency()
 
            -- Monitor death for future respawns
            humanoid.Died:Connect(function()
                spawn(function()
                    wait(0.5) -- Small delay for respawn
                    ApplyThirdPersonSettings()
                    UpdateBodyTransparency()
                    -- Clear peek point on death
                    ClearPeekPoint()
                end)
            end)
        end)
    end)

    -- Handle initial character if already exists
    if LocalPlayer.Character then
        spawn(function()
            local humanoid = LocalPlayer.Character:WaitForChild("Humanoid")
            humanoid.Died:Connect(function()
                spawn(function()
                    wait(0.5) -- Small delay for respawn
                    ApplyThirdPersonSettings()
                    UpdateBodyTransparency()
                    -- Clear peek point on death
                    ClearPeekPoint()
                end)
            end)
        end)
    end
end

