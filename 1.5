-- Chams Functions
function ApplyChams(player)
    if not player or not player.Character then return end
    if ChamInstances[player] then return end -- Already has chams
 
    local character = player.Character
    local highlight = Instance.new("Highlight")
 
    -- Simple chams with wall check option
    highlight.FillColor = ChamsEnemyColor
    highlight.OutlineColor = Color3.new(1, 1, 1) -- White outline
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    -- Wall check toggle
    if WallChams then
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    else
        highlight.DepthMode = Enum.HighlightDepthMode.Occluded
    end
    highlight.Parent = character
 
    -- Subtle glow effect
    local torso = character:FindFirstChild("Torso") or character:FindFirstChild("HumanoidRootPart")
    if torso then
        local light = Instance.new("PointLight")
        light.Color = ChamsEnemyColor
        light.Brightness = 0.5
        light.Range = 5
        light.Parent = torso
 
        ChamInstances[player] = {
            Highlight = highlight,
            Light = light
        }
    else
        ChamInstances[player] = {
            Highlight = highlight,
            Light = nil
        }
    end
end
 
function ClearChams(player)
    if not ChamInstances[player] then return end
 
    local chamData = ChamInstances[player]
    if chamData.Highlight then
        chamData.Highlight:Destroy()
    end
    if chamData.Light then
        chamData.Light:Destroy()
    end
 
    ChamInstances[player] = nil
end
 
function UpdateAllChams()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                -- Clear existing and reapply
                ClearChams(player)
                ApplyChams(player)
            end
        end
    end
end
 
-- Wall Check Function (R6 compatible)
local function IsPlayerVisible(player)
    if not player.Character then return false end
 
    -- R6 uses Torso instead of HumanoidRootPart
    local torso = player.Character:FindFirstChild("Torso")
    if not torso then return false end
 
    local origin = Camera.CFrame.Position
    local target = torso.Position
    local direction = (target - origin).Unit
    local distance = (target - origin).Magnitude
 
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, player.Character}
    raycastParams.IgnoreWater = true
 
    local raycastResult = Workspace:Raycast(origin, direction * distance, raycastParams)
 
    if not raycastResult then
        return true
    end
 
    local hitPart = raycastResult.Instance
    if hitPart then
        if hitPart:IsDescendantOf(player.Character) then
            return true
        end
        if hitPart.Transparency > 0.5 then
            return true
        end
        if hitPart.Name:lower():find("fence") or hitPart.Name:lower():find("grill") then
            return true
        end
    end
 
    return false
end
 
-- Wallbang Check - Returns true if we can shoot through the wall
local function CanWallbang(player)
    if not player.Character then return false end
 
    local torso = player.Character:FindFirstChild("Torso")
    if not torso then return false end
 
    local origin = Camera.CFrame.Position
    local target = torso.Position
    local direction = (target - origin).Unit
    local distance = (target - origin).Magnitude
 
    -- Raycast to see what we hit
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, player.Character}
    raycastParams.IgnoreWater = true
 
    local raycastResult = Workspace:Raycast(origin, direction * distance, raycastParams)
 
    if not raycastResult then
        -- No wall, player is visible
        return false
    end
 
    local hitPart = raycastResult.Instance
    if hitPart and hitPart:IsDescendantOf(player.Character) then
        -- Hit the player directly
        return false
    end
 
    -- We hit something (a wall)
    -- Check if wall is thin enough to shoot through
    local wallThickness = 0
    local currentPos = raycastResult.Position
 
    -- Cast another ray from the hit point towards the player to measure wall thickness
    local remainingDistance = distance - (currentPos - origin).Magnitude
    if remainingDistance <= 0 then return false end
 
    local secondRayParams = RaycastParams.new()
    secondRayParams.FilterType = Enum.RaycastFilterType.Blacklist
    secondRayParams.FilterDescendantsInstances = {LocalPlayer.Character, hitPart}
    secondRayParams.IgnoreWater = true
 
    local secondResult = Workspace:Raycast(currentPos, direction * remainingDistance, secondRayParams)
 
    if secondResult then
        -- Measure thickness
        wallThickness = (secondResult.Position - currentPos).Magnitude
 
        -- If we hit the player after passing through, and wall is thin enough
        if secondResult.Instance:IsDescendantOf(player.Character) and wallThickness <= WallbangThickness then
            return true
        end
    end
 
    return false
end
 
-- Function to check if player is valid target (R6 compatible)
local function IsValidTarget(player, checkWalls)
    if player == LocalPlayer then return false end
    if not player.Character then return false end
 
    local humanoid = player.Character:FindFirstChild("Humanoid")
    local torso = player.Character:FindFirstChild("Torso")
 
    if not humanoid or not torso then return false end
    if humanoid.Health <= 0 then return false end
 
    if checkWalls and WallCheckEnabled then
        -- If wallbang is enabled, check if we can shoot through walls
        if WallbangEnabled then
            return IsPlayerVisible(player) or CanWallbang(player)
        else
            return IsPlayerVisible(player)
        end
    end
 
    return true
end
 
-- Function to get closest player to screen center (R6 compatible)
local function GetClosestPlayer(checkWalls)
    local closestPlayer = nil
    local closestDistance = FOV
 
    for _, player in pairs(Players:GetPlayers()) do
        if IsValidTarget(player, checkWalls) then
            local character = player.Character
            -- R6 uses Torso instead of HumanoidRootPart
            local torso = character:FindFirstChild("Torso")
 
            if torso then
                local screenPoint, onScreen = Camera:WorldToViewportPoint(torso.Position)
 
                if onScreen then
                    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local playerPos = Vector2.new(screenPoint.X, screenPoint.Y)
                    local distance = (screenCenter - playerPos).Magnitude
 
                    if distance < closestDistance then
                        closestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end
 
    return closestPlayer
end
 
-- Silent Aim Function
local function GetSilentAimTarget()
    local closestPlayer = nil
    local closestDistance = SilentAimFOV
 
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChild("Humanoid")
 
            if head and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
 
                    if distance < closestDistance then
                        local isVisible = true
                        local canWallbang = false
 
                        -- Wall check with multiple points (head, torso)
                        if SilentAimWallCheck then
                            local cameraPos = Camera.CFrame.Position
                            local torso = player.Character:FindFirstChild("Torso")
 
                            -- Check multiple points on target
                            local checkPoints = {head.Position}
                            if torso then
                                table.insert(checkPoints, torso.Position)
                            end
 
                            local visiblePoints = 0
                            local wallbangPoints = 0
 
                            for _, point in ipairs(checkPoints) do
                                local raycastParams = RaycastParams.new()
                                raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, player.Character}
                                raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
 
                                local direction = (point - cameraPos).Unit * 1000
                                local raycastResult = workspace:Raycast(cameraPos, direction, raycastParams)
 
                                if not raycastResult then
                                    -- No obstruction, point is visible
                                    visiblePoints = visiblePoints + 1
                                else
                                    local hitDistance = (raycastResult.Position - cameraPos).Magnitude
                                    local targetDistance = (point - cameraPos).Magnitude
                                    if hitDistance >= targetDistance - 3 then
                                        -- Hit the target or very close
                                        visiblePoints = visiblePoints + 1
                                    end
                                end
                            end
 
                            -- Target is valid only if at least one point is visible
                            if visiblePoints == 0 then
                                isVisible = false
                            end
                        end
 
                        if isVisible or canWallbang then
                            closestDistance = distance
                            closestPlayer = player
                        end
                    end
                end
            end
        end
    end
 
    return closestPlayer
end
 


-- Bhop Landing Circle Functions
local function CreateLandingCircle(position)
    if not BhopCirclesEnabled then return end

    -- Remove oldest circle if at max
    if #LandingCircles >= MaxLandingCircles then
        local oldest = table.remove(LandingCircles, 1)
        if oldest and oldest.Billboard then
            oldest.Billboard:Destroy()
        end
    end

    -- Create an anchored part at the position
    local anchorPart = Instance.new("Part")
    anchorPart.Name = "LandingCircleAnchor"
    anchorPart.Size = Vector3.new(1, 1, 1)
    anchorPart.CFrame = CFrame.new(position)
    anchorPart.Anchored = true
    anchorPart.CanCollide = false
    anchorPart.Transparency = 1
    anchorPart.Parent = Workspace

    -- Create BillboardGui for the circle
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "LandingCircleBillboard"
    billboard.Adornee = anchorPart
    billboard.Size = UDim2.new(0, 100, 0, 100)
    billboard.StudsOffset = Vector3.new(0, 0.1, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = anchorPart

    -- Create the circle frame
    local circleFrame = Instance.new("Frame")
    circleFrame.Name = "Circle"
    circleFrame.Size = UDim2.new(1, 0, 1, 0)
    circleFrame.BackgroundTransparency = 1
    circleFrame.Parent = billboard

    -- Use UIStroke for the ring
    local uiStroke = Instance.new("UIStroke")
    uiStroke.Color = LandingCircleColor
    uiStroke.Thickness = 1
    uiStroke.Parent = outerRing

    -- Use UICorner to make it a circle
    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(1, 0)
    uiCorner.Parent = outerRing

    -- Inner glow
    local innerGlow = Instance.new("Frame")
    innerGlow.Name = "InnerGlow"
    innerGlow.Size = UDim2.new(0.8, 0, 0.8, 0)
    innerGlow.Position = UDim2.new(0.1, 0, 0.1, 0)
    innerGlow.BackgroundColor3 = LandingCircleColor
    innerGlow.BackgroundTransparency = 0.8
    innerGlow.BorderSizePixel = 0
    innerGlow.Parent = circleFrame

    local innerCorner = Instance.new("UICorner")
    innerCorner.CornerRadius = UDim.new(1, 0)
    innerCorner.Parent = innerGlow

    table.insert(LandingCircles, {
        Billboard = billboard,
        Anchor = anchorPart,
        OuterRing = outerRing,
        InnerGlow = innerGlow,
        UIStroke = uiStroke,
        CreationTime = tick(),
        InitialSize = 100
    })
end

local function UpdateLandingCircles()
    if not BhopCirclesEnabled then return end

    local currentTime = tick()
    for i = #LandingCircles, 1, -1 do
        local circle = LandingCircles[i]
        local age = currentTime - circle.CreationTime

        -- Expand over time (max 3 seconds)
        local maxAge = 0.8
        if age >= maxAge then
            circle.Billboard:Destroy()
            table.remove(LandingCircles, i)
        else
            -- Expand the circle
            local expansion = 1 + (age / maxAge) * 2 -- Expands 3x over lifetime
            local newSize = circle.InitialSize * expansion
            circle.Billboard.Size = UDim2.new(0, newSize, 0, newSize)

            -- Fade out
            local fade = age / maxAge
            circle.UIStroke.Transparency = fade
            circle.InnerGlow.BackgroundTransparency = 0.8 + fade * 0.2
        end
    end
end
 
-- Bhop Logic - Auto jump when hitting the ground
local WasOnGround = true
RunService.RenderStepped:Connect(function()
    if BhopEnabled and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        local rootPart = LocalPlayer.Character:FindFirstChild("Torso")
 
        if humanoid and rootPart then
            local isOnGround = humanoid.FloorMaterial ~= Enum.Material.Air
 
            -- Detect when landing (wasn't on ground, now is)
            if isOnGround and not WasOnGround then
                -- Create landing circle for bhop visual
                if BhopCirclesEnabled then
                    CreateLandingCircle(rootPart.Position - Vector3.new(0, 2.5, 0))
                end

                -- Apply strafe velocity if enabled
                if BhopStrafeEnabled then
                    local moveDirection = Vector3.new(0, 0, 0)
 
                    -- Get movement input
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        moveDirection = moveDirection + Camera.CFrame.LookVector
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        moveDirection = moveDirection - Camera.CFrame.LookVector
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                        moveDirection = moveDirection - Camera.CFrame.RightVector
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                        moveDirection = moveDirection + Camera.CFrame.RightVector
                    end
 
                    -- Apply if there's movement
                    if moveDirection.Magnitude > 0 then
                        moveDirection = Vector3.new(moveDirection.X, 0, moveDirection.Z).Unit
                        local strafeVelocity = moveDirection * BhopStrafeSpeed
                        rootPart.Velocity = Vector3.new(strafeVelocity.X, rootPart.Velocity.Y, strafeVelocity.Z)
                    end
                end
 
                -- Jump immediately
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
 
            WasOnGround = isOnGround
        end
    end
end)

local SilentAimOriginalCF = nil
local SilentAimActive = false
