-- Create the keybind
local flyKeybind = ExtraTab:CreateKeybind({
    Name = "light fly",
    CurrentKeybind = "V",
    HoldToInteract = false,
    Flag = "flyKeybind",
    Callback = function()
        if not FlyActive then
            -- Turn ON flight
            FlyActive = true
            
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                FlyConnection = game:GetService("RunService").Heartbeat:Connect(function()
                    if not FlyActive then
                        -- Disconnect if turned off
                        if FlyConnection then
                            FlyConnection:Disconnect()
                            FlyConnection = nil
                        end
                        return
                    end
                    
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local root = LocalPlayer.Character.HumanoidRootPart
                        
                        -- Calculate movement direction from WASD
                        local camera = workspace.CurrentCamera
                        local moveDirection = Vector3.new()
                        
                        -- Forward/Backward (W/S)
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                            moveDirection = moveDirection + camera.CFrame.LookVector * 30
                        elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then
                            moveDirection = moveDirection - camera.CFrame.LookVector * 30
                        end
                        
                        -- Left/Right (A/D)
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                            moveDirection = moveDirection - camera.CFrame.RightVector * 30
                        elseif UserInputService:IsKeyDown(Enum.KeyCode.D) then
                            moveDirection = moveDirection + camera.CFrame.RightVector * 30
                        end
                        
                        -- Apply velocity: forward/back/strafe movement + upward float
                        root.Velocity = Vector3.new(moveDirection.X, 8, moveDirection.Z)
                    end
                end)
            end
        else
            -- Turn OFF flight
            FlyActive = false
            if FlyConnection then
                FlyConnection:Disconnect()
                FlyConnection = nil
            end
        end
    end,
})
