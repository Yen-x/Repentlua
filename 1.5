local function SilentAim()
    if not SilentAimEnabled then return end
    if SilentAimActive then return end -- Prevent overlapping calls
 
    SilentAimActive = true
 
    -- Hit chance check
    if math.random(1, 100) > SilentAimHitChance then
        SilentAimActive = false
        return
    end
 
    local target = GetSilentAimTarget()
 
    if not target or not target.Character then
        SilentAimActive = false
        return
    end
 
    local head = target.Character:FindFirstChild("Head")
    if not head then
        SilentAimActive = false
        return
    end
 
    -- Store original camera CFrame
    SilentAimOriginalCF = Camera.CFrame
 
    -- Snap to target
    local targetPos = head.Position
    local cameraPos = Camera.CFrame.Position
    Camera.CFrame = CFrame.new(cameraPos, targetPos)
 
    -- Use executor's built-in mouse functions (pcall for safety)
    pcall(function()
        mouse1press()
    end)
 
    -- Use delay instead of task.wait to avoid interruption
    delay(SilentAimHoldTime, function()
        pcall(function()
            mouse1release()
        end)
 
        -- Restore original camera position
        if SilentAimOriginalCF then
            Camera.CFrame = SilentAimOriginalCF
            SilentAimOriginalCF = nil
        end
 
        SilentAimActive = false
    end)
end
 
 
 
-- Bullet Tracer Function
local function CreateBulletTracer(startPos, endPos)
    if not BulletTracerEnabled then return end
 
    -- Use a beam for better visibility
    local attachment0 = Instance.new("Attachment")
    local attachment1 = Instance.new("Attachment")
 
    local startPart = Instance.new("Part")
    startPart.Anchored = true
    startPart.CanCollide = false
    startPart.Transparency = 1
    startPart.Size = Vector3.new(1, 1, 1)
    startPart.CFrame = CFrame.new(startPos)
    startPart.Parent = Workspace
 
    local endPart = Instance.new("Part")
    endPart.Anchored = true
    endPart.CanCollide = false
    endPart.Transparency = 1
    endPart.Size = Vector3.new(1, 1, 1)
    endPart.CFrame = CFrame.new(endPos)
    endPart.Parent = Workspace
 
    attachment0.Parent = startPart
    attachment1.Parent = endPart
 
    local beam = Instance.new("Beam")
    beam.Attachment0 = attachment0
    beam.Attachment1 = attachment1
 
    -- Set up color (rainbow or solid)
    if BulletTracerRainbow then
        beam.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
            ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1))
        })
    else
        beam.Color = ColorSequence.new(BulletTracerColor)
    end
 
    beam.Width0 = BulletTracerThickness
    beam.Width1 = BulletTracerThickness
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.FaceCamera = true
    beam.Transparency = NumberSequence.new(0) -- Start fully visible
    beam.Parent = startPart
 
    table.insert(BulletTracers, {
        Beam = beam,
        StartPart = startPart,
        EndPart = endPart,
        CreationTime = tick(),
        IsRainbow = BulletTracerRainbow
    })
end
 

 
local function FireBulletTracerFromMuzzle(muzzle)
    if not BulletTracerEnabled then return end
 
    local startPos = muzzle.Position
    local endPos
 
    --Gets where the player is looking instead of muzzle
    local camera = Workspace.CurrentCamera
    local direction = camera.CFrame.LookVector
 
    -- Raycast to find where bullet would hit
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
 
    local raycastResult = workspace:Raycast(startPos, direction * 1000, raycastParams)
 
    if raycastResult then
        endPos = raycastResult.Position
    else
        endPos = startPos + direction * 1000
    end
 
    CreateBulletTracer(startPos, endPos)
end
 
local function UpdateBulletTracers()
    local currentTime = tick()
    for i = #BulletTracers, 1, -1 do
        local tracer = BulletTracers[i]
        local elapsed = currentTime - tracer.CreationTime
 
        if elapsed >= BulletTracerDuration then
            tracer.Beam:Destroy()
            tracer.StartPart:Destroy()
            tracer.EndPart:Destroy()
            table.remove(BulletTracers, i)
        else
            -- Fade out effect
            local fadeProgress = elapsed / BulletTracerDuration
            local transparency = fadeProgress
            tracer.Beam.Transparency = NumberSequence.new(transparency)
 
            -- Update rainbow color if enabled
            if tracer.IsRainbow then
                local hue = (currentTime * 2) % 1
                local color = Color3.fromHSV(hue, 1, 1)
                tracer.Beam.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, color),
                    ColorSequenceKeypoint.new(1, Color3.fromHSV((hue + 0.5) % 1, 1, 1))
                })
            end
        end
    end
end
 
-- Trigger Bot Function
local function TriggerBot()
    if not TriggerBotEnabled then return end
 
    local currentTime = tick()
    if currentTime - LastShotTime < TriggerBotDelay then return end
 
    local mouseTarget = Mouse.Target
    if not mouseTarget then return end
 
    local playerHit = nil
    local model = mouseTarget:FindFirstAncestorOfClass("Model")
    if model then
        playerHit = Players:GetPlayerFromCharacter(model)
    end
 
    if playerHit and playerHit ~= LocalPlayer then
        local humanoid = model:FindFirstChild("Humanoid")
        if humanoid and humanoid.Health > 0 then
            mouse1press()
            wait(TriggerBotDelay)
            mouse1release()
            LastShotTime = currentTime
        end
    end
end
 
