-- Auto Peek - G to set point, T to teleport back
local AutoPeekSpawnPoint = nil
local AutoPeekIndicator = nil
local AutoPeekAutoReturn = false

-- Function to create/update peek point indicator
local function UpdatePeekIndicator()
    if AutoPeekIndicator then
        AutoPeekIndicator:Destroy()
        AutoPeekIndicator = nil
    end
    
    if AutoPeekSpawnPoint then
        -- Create a neon cylinder indicator at the peek point
        AutoPeekIndicator = Instance.new("Part")
        AutoPeekIndicator.Name = "PeekPointIndicator"
        AutoPeekIndicator.Shape = Enum.PartType.Cylinder
        AutoPeekIndicator.Size = Vector3.new(0.2, 3, 3)
        AutoPeekIndicator.CFrame = AutoPeekSpawnPoint * CFrame.Angles(0, 0, math.rad(90))
        AutoPeekIndicator.Anchored = true
        AutoPeekIndicator.CanCollide = false
        AutoPeekIndicator.Material = Enum.Material.Neon
        AutoPeekIndicator.Color = Color3.fromRGB(0, 255, 255) -- Cyan
        AutoPeekIndicator.Transparency = 0.3
        AutoPeekIndicator.Parent = Workspace
        
        -- Add a point light for glow
        local light = Instance.new("PointLight")
        light.Color = Color3.fromRGB(0, 255, 255)
        light.Brightness = 2
        light.Range = 8
        light.Parent = AutoPeekIndicator
        
        -- Make it pulse
        spawn(function()
            while AutoPeekIndicator and AutoPeekIndicator.Parent do
                for i = 0.3, 0.7, 0.02 do
                    if not AutoPeekIndicator or not AutoPeekIndicator.Parent then break end
                    AutoPeekIndicator.Transparency = i
                    wait(0.05)
                end
                for i = 0.7, 0.3, -0.02 do
                    if not AutoPeekIndicator or not AutoPeekIndicator.Parent then break end
                    AutoPeekIndicator.Transparency = i
                    wait(0.05)
                end
            end
        end)
    end
end

-- Function to teleport back to peek point
local function TeleportToPeekPoint()
    if not AutoPeekSpawnPoint then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    if not rootPart then return end
    
    local startPosition = rootPart.Position
    local targetPosition = AutoPeekSpawnPoint.Position
    local distance = (targetPosition - startPosition).Magnitude
    
    -- Only teleport if within 35 studs to avoid anti-cheat detection
    if distance > 35 then
        Rayfield:Notify({
            Title = "Too far away",
            Content = "You must be within 35 studs of your peek point",
            Duration = 2,
            Image = "lock",
        })
        return
    end
    
    local maxIncrement = 30
    local steps = math.ceil(distance / maxIncrement)
    local stepDelay = 0.1
    
    for step = 1, steps do
        if not character or not character.Parent then break end
        
        local progress = step / steps
        local intermediatePosition = startPosition:Lerp(targetPosition, progress)
        
        rootPart.CFrame = CFrame.new(intermediatePosition) * AutoPeekSpawnPoint.Rotation
        
        wait(stepDelay)
    end
end

-- Function to clear peek point
local function ClearPeekPoint()
    AutoPeekSpawnPoint = nil
    if AutoPeekIndicator then
        AutoPeekIndicator:Destroy()
        local sound = Instance.new("Sound") --Only plays if the indicator exist
        sound.SoundId = "rbxassetid://8458185621"
        sound.Parent = workspace
        sound:Play()
        sound.Ended:Connect(function() sound:Destroy() end)
        AutoPeekIndicator = nil
    end
end

