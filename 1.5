local AimPart = "Head"  -- ADD THIS LINE after your variables section
 
local function AimAtTarget()
    if not AimbotEnabled then return end
 
    if AimlockKeybindEnabled and not IsKeyDown then return end
 
    local target = GetClosestPlayer(WallCheckEnabled)
    if not target or not target.Character then return end
 
    local character = target.Character
    local targetPart = character:FindFirstChild(AimPart)
 
    -- R6 FALLBACKS ONLY
    if not targetPart then
        if AimPart == "Head" then
            targetPart = character:FindFirstChild("Head")
        elseif AimPart == "Torso" then
            targetPart = character:FindFirstChild("Torso")
        elseif AimPart == "Left Arm" then
            targetPart = character:FindFirstChild("Left Arm")
        elseif AimPart == "Right Arm" then
            targetPart = character:FindFirstChild("Right Arm")
        elseif AimPart == "Left Leg" then
            targetPart = character:FindFirstChild("Left Leg")
        elseif AimPart == "Right Leg" then
            targetPart = character:FindFirstChild("Right Leg")
        end
    end
 
    if not targetPart then return end
 
    local camera = Workspace.CurrentCamera
    local targetPosition = targetPart.Position
    local cameraPosition = camera.CFrame.Position
    local direction = (targetPosition - cameraPosition).Unit
 
    if Smoothness > 1 then
        local currentLookVector = camera.CFrame.LookVector
        direction = currentLookVector:Lerp(direction, 1 / Smoothness)
    end
 
    camera.CFrame = CFrame.new(cameraPosition, cameraPosition + direction)
end 
 
