-- Setup mouse input for Silent Aim
local function SetupKeybindHandling()
    -- Disconnect existing connection if any
    if SilentAimInputConnection then
        SilentAimInputConnection:Disconnect()
        SilentAimInputConnection = nil
    end
 
    -- Connect to mouse button 1 down
    SilentAimInputConnection = Mouse.Button1Down:Connect(function()
        if SilentAimEnabled then
            SilentAim()
        end
    end)
