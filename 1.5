    if not loopSoundEnabled then return end
    
    -- Play immediately
    PlayLoopSound()
    
    -- Set up loop
    soundConnection = game:GetService("RunService").Stepped:Connect(function()
        if loopSoundEnabled then
            PlayLoopSound()
        end
    end)
end

