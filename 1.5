-- Fakelag Heartbeat Connection for No Send visual
RunService.Heartbeat:Connect(function()
    local Enabled = Fakelag.NoSend and Fakelag.NoSendActive

    local SelfCharacter = LocalPlayer.Character
    local SelfRootPart = SelfCharacter and SelfCharacter:FindFirstChild("HumanoidRootPart")
    local SelfHumanoid = SelfCharacter and SelfCharacter:FindFirstChildOfClass("Humanoid")
    if not SelfCharacter or not SelfRootPart or not SelfHumanoid then
        Fakelag.Line.Visible = false
        return
    end

    pcall(function()
        sethiddenproperty(SelfRootPart, "NetworkIsSleeping", Enabled)
    end)

    Fakelag.Line.Visible = Enabled
    local StartPos = Camera:WorldToViewportPoint(SelfRootPart.Position)
    Fakelag.Line.From = Vector2.new(StartPos.X, StartPos.Y)
    local EndPos, OnScreen = Camera:WorldToViewportPoint(Fakelag.EnabledPosition)
    if not OnScreen then
        Fakelag.Line.Visible = false
    end
    Fakelag.Line.To = Vector2.new(EndPos.X, EndPos.Y)
end)

-- Fakelag Main Loop
task.spawn(function()
    local Network = game:GetService("NetworkClient")

    while true do
        task.wait(1/16)
        Fakelag.LagTick = math.clamp(Fakelag.LagTick + 1, 0, Fakelag.Limit)

        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")

        if Fakelag.Enabled and humanoid and humanoid.Health > 0 then
            local limitValue = Fakelag.Method == "static" and Fakelag.Limit or math.random(1, Fakelag.Limit)

            if Fakelag.LagTick >= limitValue then
                Network:SetOutgoingKBPSLimit(9e9)
                Fakelag.LagTick = 0

                -- Clear or create Fakelag folder
                if character:FindFirstChild("Fakelag") then
                    character.Fakelag:ClearAllChildren()
                else
                    local Folder = Instance.new("Folder")
                    Folder.Name = "Fakelag"
                    Folder.Parent = character
                end

                -- Visualize fakelag ghost
                if Fakelag.Visualize then
                    character.Archivable = true
                    local Clone = character:Clone()
                    for _,Obj in next, Clone:GetDescendants() do
                        if Obj.Name == "HumanoidRootPart" or Obj:IsA("Humanoid") or Obj:IsA("LocalScript") or Obj:IsA("Script") or Obj:IsA("Decal") then
                            Obj:Destroy()
                        elseif Obj:IsA("BasePart") or Obj:IsA("MeshPart") or Obj:IsA("Part") then
                            if Obj.Transparency == 1 then
                                Obj:Destroy()
                            else
                                Obj.CanCollide = false
                                Obj.Anchored = true
                                Obj.Material = Enum.Material.Neon
                                Obj.Color = Fakelag.VisualizeColor
                                Obj.Transparency = Fakelag.VisualizeTransparency
                                Obj.Size = Obj.Size + Vector3.new(0.03, 0.03, 0.03)
                            end
                        end
                        pcall(function()
                            Obj.CanCollide = false
                        end)
                    end
                    Clone.Parent = character.Fakelag
                end
            else
                Network:SetOutgoingKBPSLimit(1)
            end
        else
            -- Cleanup when disabled
            if character then
                if character:FindFirstChild("Fakelag") then
                    character.Fakelag:ClearAllChildren()
                else
                    local Folder = Instance.new("Folder")
                    Folder.Name = "Fakelag"
                    Folder.Parent = character
                end
            end
            Network:SetOutgoingKBPSLimit(9e9)
        end
    end
end)

-- Bhop Variables
local WasOnGround = true
local FlyEnabled = false
local FlyActive = false
local FlyStartTime = 0
local FlyDuration = 1 -- seconds

-- Bhop Logic
RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        local rootPart = LocalPlayer.Character:FindFirstChild("Torso") or 
                        LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            -- Temporary Fly Logic (V key - lasts 1 second)
            if FlyEnabled and FlyActive then
                local currentTime = tick()
                if currentTime - FlyStartTime >= FlyDuration then
                    FlyActive = false
                    FlyEnabled = false
                    -- Reset velocity when fly ends
                    rootPart.Velocity = Vector3.new(0, rootPart.Velocity.Y, 0)
                else
                    -- Keep flying - maintain upward velocity
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                        rootPart.Velocity = Vector3.new(rootPart.Velocity.X, 15, rootPart.Velocity.Z)
                    end
                end
            end
            
            -- Bhop Logic (Toggle)
            if BhopEnabled then
                local isOnGround = humanoid.FloorMaterial ~= Enum.Material.Air
                
                -- Detect landing
                if isOnGround and not WasOnGround then
                    -- Apply strafe velocity on landing
                    if BhopStrafeEnabled then
                        local moveDirection = Vector3.new(0, 0, 0)
                        
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                            moveDirection = moveDirection + Camera.CFrame.LookVector
                        end
                        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                            moveDirection = moveDirection - Camera.CFrame.LookVector
                        end
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                            moveDirection = moveDirection - Camera.CFrame.RightVector
                        end
                        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                            moveDirection = moveDirection + Camera.CFrame.RightVector
                        end
                        
                        if moveDirection.Magnitude > 0 then
                            moveDirection = Vector3.new(moveDirection.X, 0, moveDirection.Z).Unit
                            local strafeVelocity = moveDirection * BhopStrafeSpeed
                            rootPart.Velocity = Vector3.new(strafeVelocity.X, rootPart.Velocity.Y, strafeVelocity.Z)
                        end
                    end
                    
                    -- Auto jump on landing
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
                
                WasOnGround = isOnGround
            end
        end
    end
end)

